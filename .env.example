# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# ── LMS connection ────────────────────────────────────────────────────────────
# Root URL of your LMS (no trailing slash)
LMS_BASE=https://your-lms-domain.com

# ── LMS credentials ───────────────────────────────────────────────────────────
# The QA/test account used to log in.
# In GitHub Actions these are stored as repository Secrets (Settings → Secrets).
LMS_USERNAME=your-qa-account@example.com
LMS_PASSWORD=your-password-here

# ── Course targeting (optional — can also be passed as CLI flags) ─────────────
# Base64-encoded course ID from the LMS URL (?courseId=...)
COURSE_ID=your-course-id-here
# Human-readable label written into every row of the report
COURSE_NAME=Your Course Name Here
